# Puerto del servicio
PORT=3003

# Variables de PostgreSQL (usadas por docker-compose y DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=chat_db
POSTGRES_PORT=5433

# Cadena de conexión (para desarrollo local sin Docker)
DATABASE_URL="postgresql://postgres:password@localhost:5433/chat_db"

# Mismo secret que auth-service usa para firmar los JWT
JWT_SECRET=super_secret_key_2026

# Origen permitido para CORS
CORS_ORIGIN=http://localhost:5173
