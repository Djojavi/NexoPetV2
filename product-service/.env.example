# Copia este archivo a .env y ajusta los valores.

# --- Base de datos propia del microservicio (product_db). NO compartir con Auth. ---
# Debe apuntar al puerto host publicado por product-db en docker-compose.yml (5434).
DATABASE_URL=postgresql://product_user:product_pass@localhost:5434/product_db?schema=public

# --- Microservicio TCP (solo lo consume el API Gateway, nunca el frontend) ---
PRODUCT_SERVICE_HOST=0.0.0.0
PRODUCT_SERVICE_PORT=3002

# --- Variables que consume docker-compose para levantar product-db ---
POSTGRES_USER=product_user
POSTGRES_PASSWORD=product_pass
POSTGRES_DB=product_db
POSTGRES_PORT=5434
