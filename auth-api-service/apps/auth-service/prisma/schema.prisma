datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String   // Aquí guardaremos el hash de bcrypt, jamás texto plano
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users") // Buenas prácticas: nombrar la tabla en minúsculas y plural en la base de datos
}